GOOGLE_API_KEY=
WEBSOCKET_SERVER= # Options: 'fast_api' or 'websocket_server'
GEMINI_LANGUAGE=en-IN # e.g. en-US, en-IN, te-IN
GEMINI_MODEL= # Optional. e.g. models/gemini-2.5-flash-native-audio-preview-12-2025
GEMINI_VOICE_ID=Puck # Optional. e.g. Puck, Charon, Fenrir, Kore, Aoede
ENABLE_LIVE_TRANSCRIPTION=1 # Set to 0 to disable partial transcripts
LIVE_TRANSCRIPT_THROTTLE_MS=100 # Lower = more updates, higher = less spam
CORS_ORIGINS=http://localhost:5173
FORCE_WS_URL= # e.g. ws://localhost:7860/ws (useful when front-end is on a different origin)
